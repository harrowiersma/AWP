{
  "position": "13-16",
  "field": "connection_details",
  "fieldDe": "Spezifizierung der Anschlüsse",
  "fieldEn": "Connection specification",
  "_comment": "Position 13-16 interpretation depends on Pos 4-5 and product family. Two rule modes are supported: 'block' matches the whole 4-character string against a table; 'per-position' decodes each of the four positions independently. Source: AWP catalog 18.1.x footers + page 18.1.1 (AVRS detail).",
  "rules": [
    {
      "_id": "AVR-HRAR-welding-block",
      "type": "block",
      "match": { "pos45In": ["00", "10"] },
      "appliesToFamilies": ["AVR", "AVB", "HRAR", "HRAB", "RV", "RVA", "RVAK", "SS"],
      "values": {
        "0000": { "labelDe": "Anschweißende Reihe 1, ohne Zubehör", "labelEn": "welding end range 1, without fittings" },
        "1100": { "labelDe": "Anschweißende ANSI Schedule 40", "labelEn": "welding end ANSI Schedule 40" }
      }
    },
    {
      "_id": "AVR-HRAR-flange-block",
      "type": "block",
      "match": { "pos45In": ["20", "30"] },
