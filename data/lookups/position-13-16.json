        "0020": { "labelDe": "DIN-Flansch glatte Dichtleiste (Form B1)", "labelEn": "DIN flange with raised face (form B1)" },
        "8810": { "labelDe": "ANSI 300 lbs Flansch mit glatter Dichtleiste (RF)", "labelEn": "ANSI 300 lbs flange with raised face" },
        "8820": { "labelDe": "ANSI 600 lbs Flansch mit glatter Dichtleiste (RF)", "labelEn": "ANSI 600 lbs flange with raised face" }
