          "values": {
            "1": { "labelDe": "ANSI 150 lbs", "labelEn": "ANSI 150 lbs" },
            "2": { "labelDe": "ANSI 300 lbs", "labelEn": "ANSI 300 lbs" },
            "3": { "labelDe": "ANSI 600 lbs", "labelEn": "ANSI 600 lbs" }
          }
