      "values": {
        "0000": { "labelDe": "DIN-Flansch mit Nut", "labelEn": "DIN flange with groove" },
        "EE00": { "labelDe": "AWP-Flansch mit Nut", "labelEn": "AWP flange with groove" },
        "8800": { "labelDe": "ANSI 150 lbs Flansch mit glatter Dichtleiste", "labelEn": "ANSI 150 lbs flange with raised face" }
      }
    },
    {
